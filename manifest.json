{
  "manifest_version": 3,
  "name": "Smart Price Checker",
  "version": "1.0",
  "description": "Find cheaper deals automatically",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.amazon.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.amazon.com/*"],
      "js": ["content.js"]
    }
  ]
}
