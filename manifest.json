{
  "manifest_version": 3,
  "name": "Smart Price Checker",
  "version": "1.1",
  "description": "Find cheaper deals anywhere",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    
    }
  ]
}
